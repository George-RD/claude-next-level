{
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(echo:*)",
      "WebFetch(domain:blog.emilburzo.com)",
      "WebFetch(domain:www.agentic-engineer.com)",
      "WebFetch(domain:claudefa.st)",
      "WebFetch(domain:paddo.dev)",
      "WebFetch(domain:www.joinformal.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:api.github.com)",
      "Skill(pr-review-toolkit:review-pr)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(cat - | python3 -c \"import sys,json; print(json.load(sys.stdin).get(\\\"tool_input\\\",{}).get(\\\"file_path\\\",\\\"\\\"))\"); [[ \"$FILE\" == *.md ]] && npx --yes markdownlint-cli2 --fix \"$FILE\" 2>/dev/null; exit 0'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
